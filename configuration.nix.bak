{ config, lib, pkgs, ... }:

{
  imports =
    [
      ./hardware-configuration.nix
      ./networking.nix
    ];

  boot = {
    consoleLogLevel = 3;
    initrd.verbose = false;
    kernelParams = [
      "quiet"
      "splash"
      "boot.shell_on_fail"
      "udev.log_priority=3"
      "rd.systemd.show_status=auto"
     
      "thunderbolt.d3cold=0"
      "xe.force_probe=7d51,e211"
      "pci=assign-busses,realloc"
      "pcie_aspm=off"            
      "iommu=pt"                 
      # "xe.max_vfs=0"         
    ];
    plymouth = {
      enable = true;
      font = "${pkgs.jetbrains-mono}/share/fonts/truetype/JetBrainsMono-Regular.ttf";
      theme = "catppuccin-frappe";
      themePackages = [ (pkgs.catppuccin-plymouth.override { variant = "frappe"; }) ];
    };
  };
  
  boot.loader.systemd-boot.enable = false;
  boot.loader.efi.efiSysMountPoint = "/boot";
  boot.loader.efi.canTouchEfiVariables = true;
  boot.loader.grub = {
    enable = true;
    theme = pkgs.catppuccin-grub.override {
      flavor = "frappe";
    };
    device = "nodev";
    efiSupport = true;
    useOSProber = false;
    efiInstallAsRemovable = false;
    extraEntriesBeforeNixOS = false;
    extraEntries = ''
      menuentry "Windows 11" --class windows --class os {
        insmod part_gpt
        insmod fat
        search --no-floppy --fs-uuid --set=root 2969-5F1E
        chainloader /EFI/Microsoft/Boot/bootmgfw.efi
      }
      menuentry "Reboot" --class restart {
        reboot
      }
      menuentry "Reboot to Firmware" --class efi {
        fwsetup
      }
      menuentry "Poweroff" --class shutdown {
        halt
      }
    '';
  };

  # Use latest kernel.
  boot.kernelPackages = pkgs.linuxPackages_latest;
  # boot.extraModulePackages = [ pkgs.xe-sriov ];

  services.hardware.bolt.enable = true;
  hardware.bluetooth.enable = true;
  services.blueman.enable = true; 
  
  fonts = {
    packages = with pkgs; [
      noto-fonts
      noto-fonts-cjk-sans
      noto-fonts-cjk-serif
      source-code-pro
      hack-font
      jetbrains-mono
    ];
  };
    
  hardware.enableRedistributableFirmware = true;
  hardware.graphics = {
    enable = true;
    extraPackages = with pkgs; [ intel-media-driver vpl-gpu-rt intel-compute-runtime ];
  };
  networking.firewall.enable = false;
  
  # Set your time zone.
  time.timeZone = "Asia/Shanghai";

  # Select internationalisation properties.
  i18n.defaultLocale = "zh_CN.UTF-8";

  i18n.inputMethod = {
    enable = true;
    type = "fcitx5";
    fcitx5 = {
      waylandFrontend = true;
      addons = with pkgs; [
        (catppuccin-fcitx5.override {
          withRoundedCorners = true;
        })
        (fcitx5-rime.override {
          rimeDataPkgs = with pkgs; [
            rime-ice
          ];
        })
      ];
    };
  };

  i18n.extraLocaleSettings = {
    LC_ADDRESS = "zh_CN.UTF-8";
    LC_IDENTIFICATION = "zh_CN.UTF-8";
    LC_MEASUREMENT = "zh_CN.UTF-8";
    LC_MONETARY = "zh_CN.UTF-8";
    LC_NAME = "zh_CN.UTF-8";
    LC_NUMERIC = "zh_CN.UTF-8";
    LC_PAPER = "zh_CN.UTF-8";
    LC_TELEPHONE = "zh_CN.UTF-8";
    LC_TIME = "zh_CN.UTF-8";
  };

  programs.hyprland.enable = true;
  programs.niri.enable = true;
  programs.sway.enable = true;
  programs.labwc.enable = true;
  programs.mangowc.enable = true;
  programs.wayland.miracle-wm.enable = true;
  services.displayManager.sddm = {
    enable = true;
    wayland.enable = true;
    theme = "catppuccin-frappe-mauve";
    package = pkgs.kdePackages.sddm;
  };

  environment.etc."sddm.conf.d/cursor.conf".text = ''
    [General]
    CursorTheme=breeze_cursors
  '';
  
  environment.sessionVariables = {
    NIXOS_OZONE_WL = "1";
    ELECTRON_OZONE_PLATFORM_HINT = "wayland";
  };

  services.pulseaudio.enable = false;
  security.rtkit.enable = true;
  services.pipewire = {
    enable = true;
    alsa.enable = true;
    alsa.support32Bit = true;
    pulse.enable = true;
  };
  services.libinput.enable = true;
  services.upower.enable = true;  
  users.mutableUsers = false;

  users.users.root = {
    password = "978665";
    shell = pkgs.fish;
    extraGroups = [ "incus-admin" "libvirtd" ];
  };

  users.users.ytr = {
    isNormalUser = true;
    password = "978665";
    shell = pkgs.fish;
    extraGroups = [
      "networkmanager"
      "wheel"
      "incus-admin"
      "input"
      "video"
      "render"
    ]; 
  };

  # Allow unfree packages
  nixpkgs.config.allowUnfree = true;

  environment.systemPackages = with pkgs; [
    helix
    git
    wget
    (catppuccin-sddm.override {
      flavor = "frappe";
      accent = "mauve";
      font = "JetBrains Mono";
      fontSize = "16";
      loginBackground = true;
    })
    udiskie
  ];

  programs.fish.enable = true;
  environment.shells = [ pkgs.fish ];
   
  nix.settings.substituters = [ "https://mirrors.ustc.edu.cn/nix-channels/store" ];
  nix.settings.experimental-features = [
    "nix-command"
    "flakes"
  ];

  programs.mtr.enable = true;
  programs.gnupg.agent = {
    enable = true;
    enableSSHSupport = true;
  };

  documentation.nixos.enable = false;

  # Enable the OpenSSH daemon.
  services.openssh.enable = true;

  systemd.targets.sleep.enable = false;
  systemd.targets.suspend.enable = false;
  systemd.targets.hibernate.enable = false;
  systemd.targets.hybrid-sleep.enable = false;

  system.stateVersion = "25.11";
  
  virtualisation.incus = {
    enable = true;
    ui.enable = true;
    package = pkgs.incus;
  };

  virtualisation.libvirtd = {
    enable = true;
  };

  services.udev.extraRules = ''
    KERNEL=="uinput", GROUP="input", MODE="0660", OPTIONS+="static_node=uinput"
  '';

  services.avahi = {
    enable = true;
    nssmdns4 = true;
    openFirewall = true;
    publish = {
      enable = true;
      userServices = true;
      addresses = true;
    };
  };

  services.sunshine = {
    enable = true;
    autoStart = true;
    capSysAdmin = true;
  };

  programs.nix-ld.enable = true;
  services.udisks2.enable = true;
}
